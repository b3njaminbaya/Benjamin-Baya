# GitHub Personal Access Token
# Scopes needed: read:user, repo (for contribution data)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# WakaTime API Key
# Find at: https://wakatime.com/settings/api-key
WAKATIME_API_KEY=your_wakatime_api_key_here

# Groq API Key (powers the AI portfolio assistant — free tier)
# Sign up and generate at: https://console.groq.com/
# Free tier: 14,400 requests/day, no credit card required
GROQ_API_KEY=your_groq_api_key_here

# Frontend URL (used for CORS — must match your Vercel deployment URL)
FRONTEND_URL=https://benjamin-mweri-baya.vercel.app

# Server port (optional, defaults to 5001)
PORT=5001
